---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../content/site';
import { getPosts } from '../lib/rss';
import { withBase } from '../lib/url';

const posts = await getPosts(site.blog.feedUrl);

function formatDate(date: Date): string {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  return `${d}/${m}/${y}`;
}
---

<BaseLayout
  title={`Blog — ${site.name}`}
  description={site.seo.defaultDescription}
>
  <nav class="topnav">
    <a href={withBase('/')}>Home</a>
  </nav>

  <h1>Blog</h1>
  <p class="intro" set:html={site.blog.intro} />

  {posts.length > 0 ? (
    <div class="post-list">
      {posts.map((post) => (
        <div class="post-row">
          <div class="post-date">{formatDate(post.date)}</div>
          <div class="post-title">
            <a href={post.link} target="_blank" rel="noopener">{post.title}</a>
          </div>
        </div>
      ))}
    </div>
  ) : (
    <p class="muted">{site.blog.emptyState}</p>
  )}
</BaseLayout>

<style>
  nav.topnav {
    margin-bottom: 40px;
  }

  h1 {
    margin: 0 0 8px;
  }

  p.intro {
    color: var(--muted);
    margin: 0 0 40px;
  }

  .post-list {
    display: flex;
    flex-direction: column;
  }
  .post-row {
    display: flex;
    gap: 20px;
    padding: 12px 0;
    border-top: 1px solid var(--line);
    align-items: baseline;
  }
  .post-row:last-child {
    border-bottom: 1px solid var(--line);
  }
  .post-date {
    flex: 0 0 92px;
    color: var(--muted);
    font-size: 13.5px;
  }
  .post-title {
    flex: 1 1 auto;
  }
  .post-title a {
    color: var(--ink);
  }

  @media (max-width: 480px) {
    .post-row {
      flex-direction: column;
      gap: 2px;
      padding: 14px 0;
    }
    .post-date {
      font-size: 12.5px;
    }
  }
</style>
