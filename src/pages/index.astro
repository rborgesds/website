---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../content/site';
import { withBase } from '../lib/url';

// Inline SVG path data for the contact icons, keyed by ContactLink.icon.
const iconPaths: Record<string, string> = {
  email:
    'M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z',
  github:
    'M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12',
  linkedin:
    'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
};
---

<BaseLayout>
  {/* Blog link hidden for now — uncomment to show it in the menu again.
  <nav class="topnav">
    <a href={withBase('/blog')}>Blog</a>
  </nav>
  */}

  <header>
    <div class="photo">
      <!-- swap for a real photo: set `photoSrc` in src/content/site.ts -->
      {site.photoSrc && <img src={site.photoSrc} alt={site.photoAlt} />}
    </div>
    <h1>{site.name}</h1>
    <div class="social">
      {site.contactLinks.map((link) => {
        const isMail = link.href.startsWith('mailto:');
        const path = link.icon ? iconPaths[link.icon] : undefined;
        return (
          <a
            href={link.href}
            aria-label={link.label}
            target={isMail ? undefined : '_blank'}
            rel={isMail ? undefined : 'noopener'}
          >
            {path ? (
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                <path d={path} />
              </svg>
            ) : (
              link.label
            )}
          </a>
        );
      })}
    </div>
  </header>

  {site.intro.map((paragraph) => (
    <p set:html={paragraph} />
  ))}

  <p class="muted" set:html={site.introMuted} />

  <p set:html={site.introClosing} />

  <hr />

  <h2>Some things I've built</h2>

  {site.projects.map((project) => (
    <div class="work-line">
      {project.wip && <span class="wip-tag">WIP</span>}{project.url ? <a href={project.url} target="_blank">{project.name}</a> : project.name} — {project.description}
      <div class="stack">{project.stack}</div>
    </div>
  ))}

  <hr />

  <h2>Where I've worked</h2>

  {site.workHistory.map((role) => (
    <div class="role-line">
      {role.title}, {role.company} <span class="when">— {role.when}</span>
      {role.description && <div class="role-desc">{role.description}</div>}
    </div>
  ))}
  <p style="margin-top:16px;"><a href={withBase(site.resumeHref)} download>Full résumé (PDF)</a></p>
</BaseLayout>

<style>
  header {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px 18px;
    margin-bottom: 40px;
  }
  .photo {
    flex: 0 0 auto;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--line);
    overflow: hidden;
  }
  .photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .work-line,
  .role-line {
    margin-bottom: 14px;
  }
  .role-line {
    margin-bottom: 20px;
  }
  .role-desc {
    margin-top: 4px;
    color: var(--muted);
    font-size: 13.5px;
  }
  .wip-tag {
    display: inline-block;
    margin-right: 8px;
    padding: 0 5px;
    border: 1px solid var(--line);
    border-radius: 3px;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--accent);
    vertical-align: 1px;
  }
  .work-line .stack,
  .role-line .when {
    color: var(--muted);
    font-size: 13.5px;
  }

  .social {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .social a {
    display: inline-flex;
    color: var(--ink);
    text-decoration: none;
  }
  .social a:hover {
    color: var(--accent);
  }
  .social svg {
    display: block;
  }
</style>
